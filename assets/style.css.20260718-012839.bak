
:root{--bg:#120f0c;--panel:#211a14;--line:#674d32;--text:#f2e6d0;--muted:#c2b398;--gold:#c99b55;--red:#7f3028}
*{box-sizing:border-box}body{margin:0;background:radial-gradient(circle at top right,#2a1713 0,transparent 32%),#120f0c;color:var(--text);font-family:Georgia,serif}
a{color:inherit}.top{padding:16px 24px;border-bottom:1px solid var(--line);background:#17120f;position:sticky;top:0;z-index:3}
.brand{font-weight:bold;letter-spacing:.08em}.sub{color:var(--muted);font-size:.85rem;margin-top:4px}
.layout{display:grid;grid-template-columns:250px 1fr;min-height:calc(100vh - 72px)}
.side{padding:18px;border-right:1px solid var(--line);background:#17120f}.side a{display:block;text-decoration:none;color:var(--muted);padding:9px 10px;border-radius:5px;margin:2px 0}.side a:hover{background:#2a2119;color:var(--text)}
.side h4{color:var(--gold);text-transform:uppercase;letter-spacing:.14em;font-size:.72rem;margin:18px 8px 6px}
main{padding:28px;max-width:1300px;width:100%}.hero{padding:34px;border:1px solid var(--line);border-radius:12px;background:linear-gradient(135deg,#261b14,#17120f);box-shadow:0 18px 45px #0008}
h1{font-size:clamp(2.2rem,5vw,4.3rem);margin:.1em 0}.eyebrow{color:var(--gold);text-transform:uppercase;letter-spacing:.2em;font-size:.75rem}.lede{color:var(--muted);line-height:1.6;max-width:800px}
.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:15px;margin:24px 0}.card{border:1px solid #5d452f;background:var(--panel);border-radius:9px;padding:18px}.card h3{color:#f0d29c;margin-top:0}.card p{color:var(--muted);line-height:1.5}
.search{width:100%;padding:11px 12px;margin:20px 0;background:#0d0b09;border:1px solid var(--line);color:var(--text);border-radius:6px}
table{width:100%;border-collapse:collapse;background:#17120f}th,td{padding:12px;border-bottom:1px solid #403022;text-align:left;vertical-align:top}th{color:var(--gold);background:#251c15}td{color:var(--muted)}
code{font-family:Consolas,monospace;background:#0d0b09;border:1px solid #433220;padding:2px 6px;border-radius:4px;color:#f0d29c}.status{display:inline-block;padding:3px 8px;border:1px solid var(--line);border-radius:999px;font-size:.75rem}.footer{border-top:1px solid var(--line);color:#8d7d68;margin-top:40px;padding-top:20px}
@media(max-width:800px){.layout{grid-template-columns:1fr}.side{display:none}main{padding:18px}}

/* Mobile wiki navigation */
@media (max-width: 800px) {
    .layout {
        grid-template-columns: 1fr;
    }

    .side,
    .sidebar {
        display: block !important;
        position: static;
        width: 100%;
        padding: 10px;
        overflow-x: auto;
        white-space: nowrap;
        border-right: none;
        border-bottom: 1px solid var(--line);
        background: #17120f;
    }

    .side h4,
    .sidebar h3 {
        display: none;
    }

    .side a,
    .sidebar .nav a {
        display: inline-block;
        padding: 9px 12px;
        margin: 2px;
        border: 1px solid var(--line);
        border-radius: 5px;
    }

    main {
        padding: 18px;
    }
}

.mobile-home-button {
    display: none;
}

@media (max-width: 800px) {
    .mobile-home-button {
        display: block;
        position: sticky;
        top: 0;
        z-index: 9999;
        padding: 12px 16px;
        background: #17120f;
        color: #f2e6d0;
        border-bottom: 1px solid var(--line);
        text-decoration: none;
        font-weight: bold;
        letter-spacing: .05em;
    }
}

/* RDR2PF_FACTIONS_ENCOUNTERS_20260718 */
.section{margin:24px 0}.faction-banner{display:block;width:100%;max-height:560px;object-fit:cover;border:1px solid var(--line);border-radius:12px;margin:24px 0;box-shadow:0 18px 45px #0008}.threat-high{border-color:var(--red);background:#2a1512;color:#f0d29c}.encounter-card .eyebrow{margin-bottom:10px}.faction-profile table{margin-top:10px}